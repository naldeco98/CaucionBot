{
    "info": {
        "name": "PPI API (CaucionBot)",
        "description": "Colección de Postman para probar los endpoints de la API de Portfolio Personal Inversiones (PPI) usados por el bot.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Login (Get Token)",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "var jsonData = pm.response.json();",
                            "if (jsonData.accessToken) {",
                            "    pm.collectionVariables.set(\"access_token\", jsonData.accessToken);",
                            "    console.log(\"Access token saved to collection variables\");",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "ApiKey",
                        "value": "{{api_key}}",
                        "type": "text"
                    },
                    {
                        "key": "ApiSecret",
                        "value": "{{api_secret}}",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/api/v1/Account/Login",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "Account",
                        "Login"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "2. Get Available Balance",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/Account/Balance",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "Account",
                        "Balance"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "3. Get Caucion Rates (Search)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/MarketData/Search?ticker=PESOS&type=Caucion",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "MarketData",
                        "Search"
                    ],
                    "query": [
                        {
                            "key": "ticker",
                            "value": "PESOS"
                        },
                        {
                            "key": "type",
                            "value": "Caucion"
                        }
                    ]
                }
            },
            "response": []
        },
        {
            "name": "4. Get Current Quote",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/MarketData/Current?ticker=PESOS - 1 DIA&type=Caucion&settlement=Inmediato",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "MarketData",
                        "Current"
                    ],
                    "query": [
                        {
                            "key": "ticker",
                            "value": "PESOS - 1 DIA"
                        },
                        {
                            "key": "type",
                            "value": "Caucion"
                        },
                        {
                            "key": "settlement",
                            "value": "Inmediato"
                        }
                    ]
                }
            },
            "response": []
        },
        {
            "name": "5. Place Caucion Order",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{access_token}}",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"ticker\": \"PESOS - 1 DIA\",\n    \"quantity\": 1000,\n    \"price\": 50.0,\n    \"side\": \"SELL\",\n    \"type\": \"Limit\",\n    \"validity\": \"Day\",\n    \"settlement\": \"Inmediato\",\n    \"assetType\": \"Caucion\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/api/v1/Order/Add",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        "api",
                        "v1",
                        "Order",
                        "Add"
                    ]
                }
            },
            "response": []
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "https://api.portfoliopersonal.com",
            "type": "string"
        },
        {
            "key": "api_key",
            "value": "TU_API_KEY_AQUI",
            "type": "string"
        },
        {
            "key": "api_secret",
            "value": "TU_API_SECRET_AQUI",
            "type": "string"
        },
        {
            "key": "access_token",
            "value": "",
            "type": "string"
        }
    ]
}